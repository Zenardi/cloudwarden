{
  "uid": "finops-governance-posture",
  "title": "FinOps — Compliance Posture",
  "tags": ["finops", "governance", "posture", "compliance"],
  "timezone": "",
  "editable": true,
  "schemaVersion": 39,
  "version": 3,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Cloud provider",
        "description": "Scope posture to one cloud (M12.4). 'All' spans every cloud.",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "finops_pg" },
        "definition": "SELECT DISTINCT provider FROM v_governance_posture ORDER BY 1",
        "query": "SELECT DISTINCT provider FROM v_governance_posture ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": "%",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "options": []
      },
      {
        "name": "framework",
        "label": "Framework",
        "description": "Compliance framework overlay (M14.13). Populated once a framework is installed.",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "finops_pg" },
        "definition": "SELECT DISTINCT framework FROM v_framework_posture ORDER BY 1",
        "query": "SELECT DISTINCT framework FROM v_framework_posture ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": "%",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "options": []
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Compliant (policy × subscription)",
      "description": "Evaluated pairs whose latest execution matched nothing.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE compliant), 0) AS \"Compliant\" FROM v_governance_posture WHERE provider LIKE '$provider'" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Non-compliant (policy × subscription)",
      "description": "Evaluated pairs whose latest execution matched >=1 resource.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE non_compliant), 0) AS \"Non-compliant\" FROM v_governance_posture WHERE provider LIKE '$provider'" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Violations (resources)",
      "description": "Sum of matched resources across the latest execution per pair.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(resources_matched), 0) AS \"Violations\" FROM v_governance_posture WHERE provider LIKE '$provider'" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Compliance rate",
      "description": "Compliant pairs / evaluated pairs. Zero when nothing has executed.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(COUNT(*) FILTER (WHERE compliant)::numeric / NULLIF(COUNT(*), 0), 4), 0) AS \"Compliance rate\" FROM v_governance_posture WHERE provider LIKE '$provider'" }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Posture split",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "pieType": "donut", "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "values": ["value"] }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE compliant), 0) AS \"Compliant\", COALESCE(COUNT(*) FILTER (WHERE non_compliant), 0) AS \"Non-compliant\" FROM v_governance_posture WHERE provider LIKE '$provider'" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Violations over time (by policy)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "showPoints": "always", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "time_series", "rawQuery": true,
          "rawSql": "SELECT e.started_at AS time, p.name AS metric, e.resources_matched AS value FROM policy_executions e JOIN policies p ON e.policy_id = p.id LEFT JOIN subscriptions s ON s.subscription_id = e.subscription_id WHERE e.started_at IS NOT NULL AND COALESCE(s.provider, 'azure') LIKE '$provider' ORDER BY e.started_at" }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Posture by provider",
      "description": "Cross-cloud rollup (M12.4): compliance per Azure/AWS/GCP.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "non_compliant" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "non_compliant", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT provider, COUNT(*) FILTER (WHERE compliant) AS compliant, COUNT(*) FILTER (WHERE non_compliant) AS non_compliant, COALESCE(SUM(resources_matched), 0) AS violations, COUNT(*) AS evaluated FROM v_governance_posture WHERE provider LIKE '$provider' GROUP BY provider ORDER BY non_compliant DESC, provider ASC" }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Posture by policy",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "non_compliant" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "non_compliant", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT policy_name, COUNT(*) FILTER (WHERE compliant) AS compliant, COUNT(*) FILTER (WHERE non_compliant) AS non_compliant, COALESCE(SUM(resources_matched), 0) AS violations, COUNT(*) AS evaluated FROM v_governance_posture WHERE provider LIKE '$provider' GROUP BY policy_name ORDER BY non_compliant DESC, policy_name ASC" }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Posture by subscription",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "non_compliant", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT subscription_id, provider, COUNT(*) FILTER (WHERE compliant) AS compliant, COUNT(*) FILTER (WHERE non_compliant) AS non_compliant, COALESCE(SUM(resources_matched), 0) AS violations, COUNT(*) AS evaluated FROM v_governance_posture WHERE provider LIKE '$provider' GROUP BY subscription_id, provider ORDER BY non_compliant DESC, subscription_id ASC" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Coverage gaps ($framework)",
      "description": "Controls with NO mapped policy (M14.13) — flagged as gaps, never counted compliant. Install a framework to populate.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE is_gap), 0) AS \"Coverage gaps\" FROM v_framework_posture WHERE framework LIKE '$framework'" }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Non-compliant controls ($framework)",
      "description": "Controls where a mapped policy currently flags a resource (M14.13).",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE status = 'non_compliant'), 0) AS \"Non-compliant\" FROM v_framework_posture WHERE framework LIKE '$framework'" }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Framework posture by control ($framework)",
      "description": "Per-control compliance for the selected framework overlay (M14.13): each control rolls up its mapped policies' latest results; a gap = no mapped policy (never compliant). Install a framework via POST /api/governance/frameworks/{id}/install to populate.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 45 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [
            { "id": "mappings", "value": [ { "type": "value", "options": {
              "compliant": { "color": "green", "index": 0 },
              "non_compliant": { "color": "red", "index": 1 },
              "not_evaluated": { "color": "yellow", "index": 2 },
              "gap": { "color": "red", "index": 3 } } } ] },
            { "id": "custom.cellOptions", "value": { "type": "color-background" } },
            { "id": "color", "value": { "mode": "fixed" } }
          ] },
          { "matcher": { "id": "byName", "options": "Violations" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background" } },
            { "id": "color", "value": { "mode": "thresholds" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }
          ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Ordinal", "desc": false } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT ordinal AS \"Ordinal\", control_id AS \"Control\", title AS \"Title\", status AS \"Status\", mapped_policies AS \"Policies\", evaluated_policies AS \"Evaluated\", violations AS \"Violations\", is_gap AS \"Gap\" FROM v_framework_posture WHERE framework LIKE '$framework' ORDER BY ordinal ASC, control_id ASC" }
      ]
    }
  ]
}
