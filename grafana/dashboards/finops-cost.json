{
  "uid": "finops-cost",
  "title": "FinOps — Cost Overview",
  "tags": ["finops", "cost"],
  "timezone": "",
  "editable": true,
  "schemaVersion": 39,
  "version": 7,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Cloud",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "finops_pg" },
        "definition": "SELECT DISTINCT provider FROM cost_snapshots ORDER BY 1",
        "query": "SELECT DISTINCT provider FROM cost_snapshots ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "%",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total cost (30d, Amortized)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(cost),0) AS \"Total\" FROM cost_snapshots WHERE cost_type = 'Amortized' AND usage_date >= CURRENT_DATE - INTERVAL '30 days' AND provider LIKE '$provider'"
        }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Cost by resource type",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT resource_type AS metric, SUM(cost) AS value FROM cost_snapshots WHERE cost_type = 'Amortized' AND usage_date >= CURRENT_DATE - INTERVAL '30 days' AND provider LIKE '$provider' GROUP BY resource_type ORDER BY value DESC"
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Cost by region",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": {
        "orientation": "horizontal",
        "xField": "location",
        "legend": { "showLegend": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT location, SUM(cost) AS cost FROM cost_snapshots WHERE cost_type = 'Amortized' AND usage_date >= CURRENT_DATE - INTERVAL '30 days' AND provider LIKE '$provider' GROUP BY location ORDER BY cost DESC"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily cost trend (Amortized)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT usage_date::timestamp AS time, SUM(cost) AS \"Amortized cost\" FROM cost_snapshots WHERE cost_type = 'Amortized' AND provider LIKE '$provider' GROUP BY usage_date ORDER BY 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top resources by cost (30d)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "cost" }, "properties": [ { "id": "unit", "value": "currencyUSD" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "cost", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT resource_id, resource_type, location, resource_group, cost FROM v_cost_by_resource ORDER BY cost DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Budgets — spend vs limit (latest crossing)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "amount" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "spend" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "actual_pct" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "actual_pct", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT b.name, b.scope_type, b.scope_value, b.period, b.amount, b.currency, e.period_key, e.threshold_pct AS last_threshold, e.actual_pct, e.amount AS spend, e.created_at FROM budgets b LEFT JOIN LATERAL (SELECT * FROM budget_threshold_events be WHERE be.budget_id = b.id ORDER BY be.created_at DESC LIMIT 1) e ON true WHERE b.enabled ORDER BY e.actual_pct DESC NULLS LAST, b.name"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Cost anomalies — recent spikes",
      "description": "Days where spend broke from its robust, weekday-aware baseline. x_baseline = actual / expected; score is the deviation in robust-sigma (MAD) units.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 34 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "expected" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "actual" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "severity" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "critical": { "color": "dark-red", "index": 0 }, "high": { "color": "dark-orange", "index": 1 }, "medium": { "color": "dark-yellow", "index": 2 }, "low": { "color": "dark-green", "index": 3 } } } ] } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "usage_date", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT usage_date, scope_type, scope_value, severity, expected, actual, ROUND((actual / NULLIF(expected, 0))::numeric, 2) AS x_baseline, ROUND(score::numeric, 1) AS score, currency, notified, created_at FROM cost_anomalies ORDER BY usage_date DESC, score DESC LIMIT 100"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Spend forecast — projection to period end",
      "description": "Projected spend to month-end/quarter-end per scope (transparent trend + weekday-seasonal model). point sits inside [lower, upper]; mape_pct is the rolling-backtest accuracy; confidence flags thin-history estimates. Latest as_of per scope+horizon.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 43 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "point" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "lower" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "upper" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "actual_to_date" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] },
          { "matcher": { "id": "byName", "options": "confidence" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "high": { "color": "dark-green", "index": 0 }, "low": { "color": "dark-orange", "index": 1 } } } ] } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "as_of", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT as_of, scope_type, scope_value, horizon, period_end, point, lower, upper, actual_to_date, ROUND(mape::numeric, 1) AS mape_pct, confidence, model, currency FROM cost_forecasts WHERE (scope_type, scope_value, horizon, as_of) IN (SELECT scope_type, scope_value, horizon, MAX(as_of) FROM cost_forecasts GROUP BY scope_type, scope_value, horizon) ORDER BY as_of DESC, scope_type, horizon LIMIT 100"
        }
      ]
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Showback — cost by owner (tag)",
      "description": "Amortized spend allocated by the `owner` tag over 30 days (M14.5). '(unallocated)' is untagged spend — surfaced, never dropped. Change the tag_key filter to allocate by CostCenter/Team/env.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 52 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "showValue": "auto", "xTickLabelRotation": 0, "legend": { "showLegend": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT tag_value, SUM(cost) AS cost FROM v_cost_by_tag WHERE tag_key = 'owner' GROUP BY tag_value ORDER BY cost DESC"
        }
      ]
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "Cost by cloud (30d, Amortized)",
      "description": "Amortized spend per cloud over 30 days (M14.11). Reads the native cost_snapshots.provider column; always shows every cloud regardless of the Cloud filter.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 61 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT provider AS metric, SUM(cost) AS value FROM cost_snapshots WHERE cost_type = 'Amortized' AND usage_date >= CURRENT_DATE - INTERVAL '30 days' GROUP BY provider ORDER BY value DESC"
        }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Kubernetes — cost by namespace (30d, allocated)",
      "description": "Managed-cluster node cost allocated to namespaces by requested resources (M14.12). Reads provider='kubernetes' / cost_type='Allocated' rows and sums the daily allocation over 30 days per cluster+namespace; independent of the Cloud filter (K8s is its own provider dimension).",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (tags->>'cluster') || '/' || (tags->>'namespace') AS metric, SUM(cost) AS value FROM cost_snapshots WHERE provider = 'kubernetes' AND cost_type = 'Allocated' AND usage_date >= CURRENT_DATE - INTERVAL '30 days' GROUP BY 1 ORDER BY value DESC"
        }
      ]
    }
  ]
}
