# ============================================================================
# CloudWarden — environment configuration
# Copy to `.env` and fill in. `.env` is gitignored; this file is committed.
# All values below are read by cloudwarden/config.py (pydantic-settings).
# ============================================================================

# --- Azure subscription --------------------------------------------------
# This is the DEFAULT subscription, seeded into the `subscriptions` table on
# first start. Add/manage additional subscriptions in the web UI (Subscriptions
# page) or via POST /api/subscriptions — each can reuse the SP below or carry its
# own credentials (e.g. a different tenant).
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --- Read-only service principal (collection) ----------------------------
# Needs: Reader + Cost Management Reader + Monitoring Reader
# (+ Log Analytics Reader if using memory metrics).
# Leave CLIENT_ID/SECRET empty to fall back to Managed Identity / az CLI.
# This SP is the shared/default credential; per-subscription SPs (set on the
# Subscriptions page) override it for that subscription only.
# The Cloud Custodian policy engine (c7n-azure) reuses these same AZURE_*
# credentials — no additional variables are required to validate/run policies.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Write-scoped service principal (remediation) ------------------------
# Only required when REMEDIATION_ENABLED=true. Custom role limited to
# compute/network write on the allowed resource groups.
AZURE_REMEDIATION_TENANT_ID=
AZURE_REMEDIATION_CLIENT_ID=
AZURE_REMEDIATION_CLIENT_SECRET=

# --- AWS account (M12.2 multi-cloud) -------------------------------------
# Onboard AWS accounts to run Cloud Custodian aws policies and ingest AWS
# resources into AssetDB (provider='aws'). Onboarding validates credentials via
# STS get_caller_identity. Keys are optional — the live path falls back to the
# ambient role (IRSA / instance profile / env). Unset in mock dev.
AWS_ACCOUNT_ID=
AWS_DEFAULT_REGION=us-east-1
AWS_ROLE_ARN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- GCP project (M12.3 multi-cloud) -------------------------------------
# Onboard GCP projects to run Cloud Custodian gcp policies and ingest GCP
# resources into AssetDB (provider='gcp'). Onboarding validates credentials via
# Resource Manager get_project. GCP_SERVICE_ACCOUNT_JSON is a path to (or the
# inline body of) a service-account key; the live path otherwise uses Application
# Default Credentials. NOTE: live GCP execution needs the optional `c7n-gcp`
# extra (see backend/requirements.txt) — mock/onboarding/ingestion work without it.
GCP_PROJECT_ID=
GCP_DEFAULT_REGION=us-central1
GCP_SERVICE_ACCOUNT_JSON=

# --- Memory metrics (optional) -------------------------------------------
# Log Analytics workspace GUID. If empty, memory-based rules are skipped
# and downsize recommendations run CPU-only at reduced confidence.
LOG_ANALYTICS_WORKSPACE_ID=

# --- Event Grid (real-time enforcement) ----------------------------------
# Master switch for event-mode ingestion. When false, POST /api/events/azure
# accepts deliveries with 202 but stores/triggers nothing — pause real-time
# enforcement without tearing down the Event Grid subscription.
EVENT_MODE_ENABLED=true
# Optional shared key authenticating Event Grid deliveries to
# POST /api/events/azure. Empty = accept all deliveries (local/mock dev). When
# set, a delivery must present it via the `x-events-key` header or `?key=` query
# param, or it is rejected with 403.
AZURE_EVENTGRID_SHARED_KEY=

# --- AI provider ---------------------------------------------------------
# AI_PROVIDER: anthropic | openai   (openai = any OpenAI-compatible endpoint)
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
# Anthropic key (or set AI_API_KEY). For local models, point AI_BASE_URL at
# your OpenAI-compatible server, e.g. http://host.docker.internal:11434/v1
ANTHROPIC_API_KEY=
AI_API_KEY=
AI_BASE_URL=
AI_MAX_CANDIDATES=40
AI_MAX_TOKENS=8000

# --- Notification transports (M8.2) --------------------------------------
# Slack incoming-webhook URL used when a notification channel does not carry
# its own target/webhook. Empty = no default (each Slack channel must supply
# its own webhook via the channel target or config).
SLACK_WEBHOOK_URL=
# SMTP relay for the email transport. Leave SMTP_HOST empty to disable live
# email (injected clients still work in tests). SMTP_FROM is the default sender
# when a channel does not override it via config `from`.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=finops@localhost
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Enterprise transports (M8.3) ----------------------------------------
# Microsoft Teams incoming-webhook URL used when a channel carries no target.
TEAMS_WEBHOOK_URL=
# Jira — one instance, many projects. A channel target selects the project;
# these are the instance-level base URL, credentials (email + API token) and
# defaults. Leave JIRA_BASE_URL empty to disable live Jira delivery.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=
JIRA_ISSUE_TYPE=Task
# ServiceNow — instance URL + credentials for the Table API (create incident).
# Leave SERVICENOW_INSTANCE_URL empty to disable live ServiceNow delivery.
SERVICENOW_INSTANCE_URL=
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# --- Database ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://finops:finops@db:5432/finops

# --- Analysis windows & thresholds ---------------------------------------
METRIC_LOOKBACK_DAYS=14
COST_LOOKBACK_DAYS=30
MIN_DATA_COMPLETENESS=0.8
SHUTDOWN_CPU_P95=3.0
SHUTDOWN_CPU_MAX=5.0
DOWNSIZE_CPU_P95=40.0
DOWNSIZE_CPU_MAX=80.0
DOWNSIZE_MEM_P95=50.0

# --- Commitment coverage & RI/Savings-Plan recommendations (M14.1) -------
# A commitment utilized below this percent wastes its idle share (advisory waste).
COMMITMENT_UNDER_UTILIZED_PCT=80.0
# Surface a commitment as "expiring soon" within this many days of its expiry.
COMMITMENT_EXPIRING_WITHIN_DAYS=60
# Minimum steady-state baseline ($/hr) to size a purchase — smaller/burstier usage
# (window minimum below this) yields no purchase recommendation.
COMMITMENT_MIN_HOURLY=0.5

# --- Budgets & threshold alerting (M14.2) --------------------------------
# Evaluate budgets vs actual spend each pipeline run / scheduler tick and fire a
# threshold-crossing notification through the existing transports. Set false to
# skip budget evaluation entirely.
BUDGET_ALERTS_ENABLED=true

# --- Cost anomaly detection (M14.3) --------------------------------------
# Detect abnormal daily spend over cost_snapshots each run and alert on new spikes.
ANOMALY_DETECTION_ENABLED=true
# Signal gate: with fewer than this many baseline days, nothing is ever flagged.
ANOMALY_MIN_HISTORY_DAYS=14
# Robust-sigma (MAD units) above which a day is anomalous; LOWER = more sensitive.
ANOMALY_SENSITIVITY=3.5
# Trailing window (days) feeding the robust, weekday-aware baseline.
ANOMALY_WINDOW_DAYS=45
# Deseasonalize by weekday before scoring (weekend/weekday spend effects).
ANOMALY_SEASONALITY=true
# Notification channel *name* new anomalies alert through; empty = record silently.
ANOMALY_ALERT_CHANNEL=
# Demo only: overlay a seeded spend spike on the mock cost series so a FINOPS_MOCK
# stack surfaces a detectable anomaly out of the box. Leave false outside demos.
ANOMALY_MOCK_SPIKE=false

# --- Cost forecasting (M14.4) --------------------------------------------
# Project spend to month-end/quarter-end each run (transparent trend + weekday-seasonal
# model) and feed the forecasted-to-exceed budget rule. Set false to skip forecasting.
FORECAST_ENABLED=true
# Trailing window (days) the trend + weekday seasonality are fit on.
FORECAST_WINDOW_DAYS=90
# Below this many baseline days, emit a clearly-labelled low-confidence linear estimate
# (never a silently fabricated number).
FORECAST_MIN_HISTORY_DAYS=14
# Rolling one-step-ahead backtest folds feeding the recorded MAPE (accuracy).
FORECAST_BACKTEST_DAYS=14
# Prediction-interval confidence level (percent): 80/85/90/95/99.
FORECAST_CONFIDENCE_PCT=80
# Deseasonalize by weekday before projecting (weekend/weekday spend effects).
FORECAST_SEASONALITY=true

# --- Showback / chargeback by tag → team (M14.5) -------------------------
# Default tag key spend is allocated by (CostCenter / Owner / Team / env). The mock
# inventory tags resources with `owner`, so that is the out-of-box demo key; set to
# CostCenter in production.
SHOWBACK_TAG_KEY=owner
# JSON object mapping a tag value → a team name, e.g. {"web-team":"Platform"}. A team
# member then sees only their team's allocation. Blank/{} = no team bindings.
SHOWBACK_TEAM_MAP={}
# A tag value treated as *shared* cost, redistributed across the other allocated
# buckets; blank = no shared split.
SHOWBACK_SHARED_TAG_VALUE=
# How a shared bucket is split across the others: even | proportional (by spend).
SHOWBACK_SPLIT_METHOD=even

# --- Configuration drift detection (M14.7) -------------------------------
# Diff live AssetDB config vs a per-resource desired-state baseline each run and record
# added/removed/changed field paths. Volatile/noise fields are excluded so unchanged
# resources never drift. Set false to skip drift detection entirely.
DRIFT_DETECTION_ENABLED=true
# Notification channel *name* new drift findings alert through; empty = record silently.
DRIFT_ALERT_CHANNEL=

# --- Remediation guardrails ----------------------------------------------
# REMEDIATION_ENABLED=false => dry-run only (no Azure writes).
REMEDIATION_ENABLED=false
# Comma-separated resource-group allow-list ("*" = any). Empty = none allowed.
ALLOWED_RESOURCE_GROUPS=
# A resource carrying this tag key=value is never touched. The built-in
# `custodian:exclude` tag is always honoured in addition to this one.
EXCLUDE_TAG=finops:exclude
# Comma-separated allow-list of Custodian action types policy actions may perform
# (e.g. "tag,stop"). Empty = no per-type restriction (any action allowed).
ALLOWED_ACTIONS=

# --- GitOps policy sync --------------------------------------------------
# Git is the single source of truth for policies. Point at a Git repo of Cloud
# Custodian policy YAML; sync (on every boot + POST /api/policies/sync)
# clones/pulls it, upserts by name (source=gitops), and DELETES gitops policies
# no longer in the repo. Leave the URL blank to fall back to a local dir. Invalid
# files are skipped and reported; new policies land disabled; re-sync is idempotent.
GITOPS_REPO_URL=
GITOPS_BRANCH=main
# Path within the repo holding the policy .yml/.yaml/.json files.
GITOPS_POLICY_PATH=policies
# Local policy dir used when GITOPS_REPO_URL is blank. Blank → the bundled
# cloudwarden/policies/ (10 disabled-by-default FinOps/governance defaults).
GITOPS_LOCAL_PATH=

# --- Runtime -------------------------------------------------------------
# FINOPS_MOCK=1 uses recorded fixtures instead of calling Azure (offline dev).
FINOPS_MOCK=1
RUN_INTERVAL_SECONDS=86400
# Pull-mode policy execution runs on its own cadence, independent of the
# cost-collection pipeline above.
POLICY_RUN_INTERVAL_SECONDS=86400
APP_DATA_DIR=/data
# Optional scheduled governance report (M9.4): off by default. When enabled, the
# scheduler writes a timestamped CSV export to APP_DATA_DIR on this cadence. The
# on-demand export (GET /api/governance/export?format=csv|json) needs no flag.
GOVERNANCE_REPORT_ENABLED=false
GOVERNANCE_REPORT_INTERVAL_SECONDS=86400

# --- Access control / RBAC (M11.1) --------------------------------------
# When true, mutating API endpoints require the caller (X-Principal header) to hold
# the endpoint's permission via a role binding. Off by default so the API stays
# backward-compatible until roles/bindings are provisioned. Default roles
# (admin/editor/viewer) are always seeded; RBAC_BOOTSTRAP_ADMIN names a principal
# auto-bound to admin so it can provision all other bindings.
RBAC_ENABLED=false
RBAC_BOOTSTRAP_ADMIN=

# --- SSO / OIDC authentication (M11.3) -----------------------------------
# When true, API requests carry identity as a verified OIDC bearer token (or a
# first-party session cookie issued by /api/auth/callback); the verified subject
# becomes the RBAC principal. Off by default so local/mock dev needs no IdP.
# Enable together with RBAC_ENABLED to actually protect writes.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
# Which verified claim becomes the principal (sub | email | preferred_username).
OIDC_PRINCIPAL_CLAIM=sub
# Optional static RS256 public key (PEM) for verification instead of the issuer JWKS.
OIDC_PUBLIC_KEY=
# Secret for signing first-party session tokens (HS256). Empty falls back to the
# client secret; set a dedicated, high-entropy value in production.
SESSION_SECRET=

# --- Grafana -------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin
