# ============================================================================
# Azure FinOps Optimizer — environment configuration
# Copy to `.env` and fill in. `.env` is gitignored; this file is committed.
# All values below are read by azure_finops/config.py (pydantic-settings).
# ============================================================================

# --- Azure subscription --------------------------------------------------
# This is the DEFAULT subscription, seeded into the `subscriptions` table on
# first start. Add/manage additional subscriptions in the web UI (Subscriptions
# page) or via POST /api/subscriptions — each can reuse the SP below or carry its
# own credentials (e.g. a different tenant).
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --- Read-only service principal (collection) ----------------------------
# Needs: Reader + Cost Management Reader + Monitoring Reader
# (+ Log Analytics Reader if using memory metrics).
# Leave CLIENT_ID/SECRET empty to fall back to Managed Identity / az CLI.
# This SP is the shared/default credential; per-subscription SPs (set on the
# Subscriptions page) override it for that subscription only.
# The Cloud Custodian policy engine (c7n-azure) reuses these same AZURE_*
# credentials — no additional variables are required to validate/run policies.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Write-scoped service principal (remediation) ------------------------
# Only required when REMEDIATION_ENABLED=true. Custom role limited to
# compute/network write on the allowed resource groups.
AZURE_REMEDIATION_TENANT_ID=
AZURE_REMEDIATION_CLIENT_ID=
AZURE_REMEDIATION_CLIENT_SECRET=

# --- Memory metrics (optional) -------------------------------------------
# Log Analytics workspace GUID. If empty, memory-based rules are skipped
# and downsize recommendations run CPU-only at reduced confidence.
LOG_ANALYTICS_WORKSPACE_ID=

# --- Event Grid (real-time enforcement) ----------------------------------
# Master switch for event-mode ingestion. When false, POST /api/events/azure
# accepts deliveries with 202 but stores/triggers nothing — pause real-time
# enforcement without tearing down the Event Grid subscription.
EVENT_MODE_ENABLED=true
# Optional shared key authenticating Event Grid deliveries to
# POST /api/events/azure. Empty = accept all deliveries (local/mock dev). When
# set, a delivery must present it via the `x-events-key` header or `?key=` query
# param, or it is rejected with 403.
AZURE_EVENTGRID_SHARED_KEY=

# --- AI provider ---------------------------------------------------------
# AI_PROVIDER: anthropic | openai   (openai = any OpenAI-compatible endpoint)
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
# Anthropic key (or set AI_API_KEY). For local models, point AI_BASE_URL at
# your OpenAI-compatible server, e.g. http://host.docker.internal:11434/v1
ANTHROPIC_API_KEY=
AI_API_KEY=
AI_BASE_URL=
AI_MAX_CANDIDATES=40
AI_MAX_TOKENS=8000

# --- Notification transports (M8.2) --------------------------------------
# Slack incoming-webhook URL used when a notification channel does not carry
# its own target/webhook. Empty = no default (each Slack channel must supply
# its own webhook via the channel target or config).
SLACK_WEBHOOK_URL=
# SMTP relay for the email transport. Leave SMTP_HOST empty to disable live
# email (injected clients still work in tests). SMTP_FROM is the default sender
# when a channel does not override it via config `from`.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=finops@localhost
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Enterprise transports (M8.3) ----------------------------------------
# Microsoft Teams incoming-webhook URL used when a channel carries no target.
TEAMS_WEBHOOK_URL=
# Jira — one instance, many projects. A channel target selects the project;
# these are the instance-level base URL, credentials (email + API token) and
# defaults. Leave JIRA_BASE_URL empty to disable live Jira delivery.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=
JIRA_ISSUE_TYPE=Task
# ServiceNow — instance URL + credentials for the Table API (create incident).
# Leave SERVICENOW_INSTANCE_URL empty to disable live ServiceNow delivery.
SERVICENOW_INSTANCE_URL=
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# --- Database ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://finops:finops@db:5432/finops

# --- Analysis windows & thresholds ---------------------------------------
METRIC_LOOKBACK_DAYS=14
COST_LOOKBACK_DAYS=30
MIN_DATA_COMPLETENESS=0.8
SHUTDOWN_CPU_P95=3.0
SHUTDOWN_CPU_MAX=5.0
DOWNSIZE_CPU_P95=40.0
DOWNSIZE_CPU_MAX=80.0
DOWNSIZE_MEM_P95=50.0

# --- Remediation guardrails ----------------------------------------------
# REMEDIATION_ENABLED=false => dry-run only (no Azure writes).
REMEDIATION_ENABLED=false
# Comma-separated resource-group allow-list ("*" = any). Empty = none allowed.
ALLOWED_RESOURCE_GROUPS=
# A resource carrying this tag key=value is never touched. The built-in
# `custodian:exclude` tag is always honoured in addition to this one.
EXCLUDE_TAG=finops:exclude
# Comma-separated allow-list of Custodian action types policy actions may perform
# (e.g. "tag,stop"). Empty = no per-type restriction (any action allowed).
ALLOWED_ACTIONS=

# --- GitOps policy sync --------------------------------------------------
# Point at a Git repo of Cloud Custodian policy YAML; POST /api/policies/sync
# clones/pulls it and upserts the policies (source=gitops). Leave the URL blank
# to disable. Invalid files are skipped and reported; re-sync is idempotent.
GITOPS_REPO_URL=
GITOPS_BRANCH=main
# Path within the repo holding the policy .yml/.yaml/.json files.
GITOPS_POLICY_PATH=policies

# --- Runtime -------------------------------------------------------------
# FINOPS_MOCK=1 uses recorded fixtures instead of calling Azure (offline dev).
FINOPS_MOCK=1
RUN_INTERVAL_SECONDS=86400
# Pull-mode policy execution runs on its own cadence, independent of the
# cost-collection pipeline above.
POLICY_RUN_INTERVAL_SECONDS=86400
APP_DATA_DIR=/data
# Optional scheduled governance report (M9.4): off by default. When enabled, the
# scheduler writes a timestamped CSV export to APP_DATA_DIR on this cadence. The
# on-demand export (GET /api/governance/export?format=csv|json) needs no flag.
GOVERNANCE_REPORT_ENABLED=false
GOVERNANCE_REPORT_INTERVAL_SECONDS=86400

# --- Grafana -------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin
